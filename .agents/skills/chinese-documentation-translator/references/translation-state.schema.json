{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learn-open-source/.agents/skills/chinese-documentation-translator/translation-state.schema.json",
  "title": "翻译状态追踪文件格式",
  "description": "记录某个项目/目录的翻译进度、源文件版本和当前状态，支持增量翻译和源文件更新检测。",
  "type": "object",
  "required": ["project", "translator_version", "created_at", "updated_at", "files"],
  "properties": {
    "project": {
      "type": "object",
      "description": "被翻译项目的元数据",
      "required": ["name", "source_path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "项目名称，用于标识此翻译任务",
          "examples": ["self/matt-pocock-skills"]
        },
        "source_path": {
          "type": "string",
          "description": "被翻译目录的绝对路径或相对于仓库根的路径"
        },
        "source_type": {
          "type": "string",
          "enum": ["plugin-marketplace", "skill-collection", "single-skill", "generic-docs"],
          "description": "源目录的结构类型，影响翻译流程选择"
        },
        "source_repo_url": {
          "type": "string",
          "description": "源仓库的 URL（如有）"
        }
      }
    },
    "translator_version": {
      "type": "string",
      "description": "使用的翻译器技能版本号",
      "examples": ["1.0.0", "2.0.0"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "此状态文件首次创建时间（ISO 8601）"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "此状态文件最后更新时间（ISO 8601）"
    },
    "source_version": {
      "type": "object",
      "description": "翻译时所基于的源文件版本信息",
      "properties": {
        "git_commit": {
          "type": "string",
          "description": "翻译时源仓库的 HEAD commit hash（git rev-parse HEAD）"
        },
        "git_commit_short": {
          "type": "string",
          "description": "短 commit hash（前 7 位）"
        },
        "git_branch": {
          "type": "string",
          "description": "翻译时的分支名"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time",
          "description": "版本信息采集时间"
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "翻译进度汇总（自动计算）",
      "properties": {
        "total_files": { "type": "integer" },
        "completed": { "type": "integer" },
        "in_progress": { "type": "integer" },
        "pending": { "type": "integer" },
        "needs_update": { "type": "integer" },
        "skipped": { "type": "integer" }
      }
    },
    "phases": {
      "type": "array",
      "description": "各翻译阶段的执行状态",
      "items": {
        "type": "object",
        "required": ["phase", "name", "status"],
        "properties": {
          "phase": {
            "type": "integer",
            "description": "阶段编号（1-6，对应 SOP 中的阶段）"
          },
          "name": {
            "type": "string",
            "description": "阶段名称",
            "examples": ["Phase 1: README 文件", "Phase 2: SKILL.md 文件"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in-progress", "completed", "skipped"],
            "description": "阶段状态"
          },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "notes": {
            "type": "string",
            "description": "阶段备注（如跳过的原因）"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "description": "每个被翻译文件的详细状态",
      "items": {
        "type": "object",
        "required": ["relative_path", "file_type", "status"],
        "properties": {
          "relative_path": {
            "type": "string",
            "description": "相对于 project.source_path 的文件路径"
          },
          "file_type": {
            "type": "string",
            "enum": ["SKILL.md", "README.md", "command.md", "plugin.json", "marketplace.json", "py", "sh", "other-md", "config"],
            "description": "文件类型分类"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in-progress", "completed", "needs-update", "skipped"],
            "description": "翻译状态：pending=待翻译, in-progress=进行中, completed=已完成, needs-update=源文件已更新需重新翻译, skipped=跳过"
          },
          "source_hash": {
            "type": "string",
            "description": "翻译时所基于的源文件 SHA-256 hash，用于检测源文件是否变更"
          },
          "source_size_bytes": {
            "type": "integer",
            "description": "翻译时源文件的大小（字节），辅助检测变更"
          },
          "translated_at": {
            "type": "string",
            "format": "date-time",
            "description": "翻译完成时间"
          },
          "translator_notes": {
            "type": "string",
            "description": "翻译备注（如特殊处理说明、跳过的原因）"
          },
          "category": {
            "type": "string",
            "description": "文件所属的分类目录（如 engineering、productivity 等）"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "翻译后验证记录",
      "properties": {
        "last_validated_at": { "type": "string", "format": "date-time" },
        "validator_used": {
          "type": "string",
          "description": "使用的验证器（如 validate_plugins.py、人工抽查 等）"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "pass-with-warnings", "fail"],
          "description": "验证结果"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "severity": { "type": "string", "enum": ["error", "warning", "info"] },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
